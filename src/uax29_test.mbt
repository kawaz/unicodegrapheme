  // ÷ 000D ÷ 0001 ÷
  let input = "\u{000D}\u{0001}"
  let g = graphemes(input)
  assert_eq(g.length(), 2)
  // cluster 0: [000D]
  assert_eq(g[0].to_string(), "\u{000D}")
  // cluster 1: [0001]
  assert_eq(g[1].to_string(), "\u{0001}")
}

///|
test "UAX29/0054: <CARRIAGE RETURN / COMBINING DIAERESIS / <START OF HEADING>" {
  // ÷ 000D ÷ 0308 ÷ 0001 ÷
  let input = "\u{000D}\u{0308}\u{0001}"
  let g = graphemes(input)
  assert_eq(g.length(), 3)
  // cluster 0: [000D]
  assert_eq(g[0].to_string(), "\u{000D}")
  // cluster 1: [0308]
  assert_eq(g[1].to_string(), "\u{0308}")
  // cluster 2: [0001]
  assert_eq(g[2].to_string(), "\u{0001}")
}

