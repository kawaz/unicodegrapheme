  let input = "\u{0900}\u{0308}\u{200C}"
  let g = graphemes(input)
  assert_eq(g.length(), 1)
  // cluster 0: [0900 0308 200C]
  assert_eq(g[0].to_string(), "\u{0900}\u{0308}\u{200C}")
}

