  let input = "\u{0A03}\u{0308}\u{0A03}"
  let g = graphemes(input)
  assert_eq(g.length(), 1)
  // cluster 0: [0A03 0308 0A03]
  assert_eq(g[0].to_string(), "\u{0A03}\u{0308}\u{0A03}")
}

