  let input = "\u{AC00}\u{0904}"
  let g = graphemes(input)
  assert_eq(g.length(), 2)
  // cluster 0: [AC00]
  assert_eq(g[0].to_string(), "\u{AC00}")
  // cluster 1: [0904]
  assert_eq(g[1].to_string(), "\u{0904}")
}

