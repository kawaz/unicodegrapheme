  assert_eq(g.length(), 2)
  // cluster 0: [0061 1F3FF]
  assert_eq(g[0].to_string(), "\u{0061}\u{1F3FF}")
  // cluster 1: [1F476]
  assert_eq(g[1].to_string(), "\u{1F476}")
}

///|
test "UAX29/1077: LATIN SMALL LETTER A / EMOJI MODIFIER FITZPATRICK ... / BABY / ZERO WIDTH JOINER / OCTAGONAL SIGN" {
  // ÷ 0061 × 1F3FF ÷ 1F476 × 200D × 1F6D1 ÷
  let input = "\u{0061}\u{1F3FF}\u{1F476}\u{200D}\u{1F6D1}"
  let g = graphemes(input)
  assert_eq(g.length(), 2)
  // cluster 0: [0061 1F3FF]
  assert_eq(g[0].to_string(), "\u{0061}\u{1F3FF}")
  // cluster 1: [1F476 200D 1F6D1]
  assert_eq(g[1].to_string(), "\u{1F476}\u{200D}\u{1F6D1}")
}

///|
test "UAX29/1078: BABY / EMOJI MODIFIER FITZPATRICK ... / COMBINING DIAERESIS / ZERO WIDTH JOINER / BABY / EMOJI MODIFIER FITZPATRICK ..." {
  // ÷ 1F476 × 1F3FF × 0308 × 200D × 1F476 × 1F3FF ÷
  let input = "\u{1F476}\u{1F3FF}\u{0308}\u{200D}\u{1F476}\u{1F3FF}"
  let g = graphemes(input)
  assert_eq(g.length(), 1)
  // cluster 0: [1F476 1F3FF 0308 200D 1F476 1F3FF]
  assert_eq(
    g[0].to_string(),
    "\u{1F476}\u{1F3FF}\u{0308}\u{200D}\u{1F476}\u{1F3FF}",
  )
}

///|
