  let input = "\u{231A}\u{0020}"
  let g = graphemes(input)
  assert_eq(g.length(), 2)
  // cluster 0: [231A]
  assert_eq(g[0].to_string(), "\u{231A}")
  // cluster 1: [0020]
  assert_eq(g[1].to_string(), "\u{0020}")
}

///|
test "UAX29/0784: WATCH / COMBINING DIAERESIS / SPACE" {
  // ÷ 231A × 0308 ÷ 0020 ÷
  let input = "\u{231A}\u{0308}\u{0020}"
  let g = graphemes(input)
  assert_eq(g.length(), 2)
  // cluster 0: [231A 0308]
  assert_eq(g[0].to_string(), "\u{231A}\u{0308}")
  // cluster 1: [0020]
  assert_eq(g[1].to_string(), "\u{0020}")
}

